# =====================================================================
# 競輪予想システム 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、値を設定してください。
# .env.local は .gitignore で除外されています（コミットしないこと）
# =====================================================================

# --- Supabase ---
# Supabase プロジェクトの API URL（サーバーサイドで使用）
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Supabase Service Role キー（サーバーサイド専用。絶対にクライアントへ露出させないこと）
# 注意: 本番環境では必ずこの環境変数を設定してください
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- 管理エンドポイント認証 ---
# /api/admin/* へのアクセスに使用するキー（任意の強いランダム文字列）
ADMIN_API_KEY=your-strong-random-admin-api-key

# --- GitHub Actions 手動起動用 ---
# GitHub リポジトリオーナー名（ユーザー名 or Org 名）
GITHUB_OWNER=your-github-username

# GitHub リポジトリ名
GITHUB_REPO=cycleboy

# GitHub Personal Access Token（Fine-grained tokens 推奨、workflow スコープ必須）
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# --- スクレイピング設定 ---
# リクエスト間の待機時間（ミリ秒）。デフォルト: 500
SCRAPE_DELAY_MS=500

# --- Gemini API ---
# Gemini APIキー（必須）
# 注意: 本番環境では必ずこの環境変数を設定してください
# 取得方法: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Geminiモデル名（デフォルト: gemini-2.0-flash-exp）
# 利用可能なモデル: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash-exp, gemini-2.5-pro-exp
# 注意: 本番環境で使用するモデルが存在することを確認してください
GEMINI_MODEL=gemini-model
