{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build",
    "crons": [
        {
            "path": "/api/cron/cleanup",
            "schedule": "0 20 * * *"
        },
        {
            "path": "/api/cron/scrape",
            "schedule": "15 20 * * *"
        }
    ]
}